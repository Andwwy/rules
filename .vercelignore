# Keep the Vercel upload small. sample.db (the source documents) and annotate.py
# ARE needed — do NOT ignore them. annotations.db is replaced by MotherDuck in prod.
.git
.claude
__pycache__/
*.pyc
.venv/

# local annotations DB + backups (MotherDuck is used in prod)
annotations.db
annotations.backup-*.db

# large source DBs not used by the app
processed.db
rules.db
rules2.db
rules3.db

# crawler / one-off scripts not needed at runtime
crawler.py
crawler2.py
crawler3.py
process.py
import_csv.py
query.py
serve.py

# docker assets not used by Vercel
Dockerfile
docker-compose.yml
.dockerignore
